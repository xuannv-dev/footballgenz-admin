<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">

    <title>Admin Panel</title>

    <!-- ================= CSS ================= -->

    <link
        href="/plugins/bootstrap/css/bootstrap.css"
        rel="stylesheet">

    <link
        href="/plugins/node-waves/waves.css"
        rel="stylesheet" />

    <link
        href="/plugins/animate-css/animate.css"
        rel="stylesheet" />

    <link
        href="/css/style.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/stylesheets/admin.css">

    <link
        rel="stylesheet"
        href="/stylesheets/style.css">

    <!-- ================= ICON ================= -->

    <link
        href="https://fonts.googleapis.com/icon?family=Material+Icons"
        rel="stylesheet">

    <!-- ================= SUMMERNOTE ================= -->

    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote.min.css">

    <!-- ================= CHART ================= -->

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body class="theme-red">

<!-- ================= TOPBAR ================= -->

<nav class="navbar">

    <div class="container-fluid">

        <div class="navbar-header">

            <a
                class="navbar-brand"
                href="/admin">

                ⚽ ADMIN FOOTBALL GEN Z

            </a>

        </div>

        <ul class="nav navbar-nav navbar-right">

            <li>

                <a href="/auth/logout">

                    <i class="material-icons">
                        logout
                    </i>

                </a>

            </li>

        </ul>

    </div>

</nav>

<!-- ================= SIDEBAR ================= -->

<section>

    <aside
        id="leftsidebar"
        class="sidebar">

        <!-- USER -->

        <div class="user-info">

            <div class="image">

                <img
                    src="/images/user.png"
                    width="48">

            </div>

            <div class="info-container">

                <div class="name">

                    <%= user
                        ? (user.firstname + ' ' + user.lastname)
                        : 'Admin'
                    %>

                </div>

                <div class="email">

                    <%= user ? user.email : '' %>

                </div>

            </div>

        </div>

        <!-- MENU -->

        <div class="menu">

            <ul class="list">

                <li class="header">
                    QUẢN TRỊ HỆ THỐNG
                </li>

                <!-- DASHBOARD -->

                <li>

                    <a href="/admin">

                        <i class="material-icons">
                            dashboard
                        </i>

                        <span>
                            Dashboard
                        </span>

                    </a>

                </li>

                <!-- PRODUCT -->

                <li>

                    <a
                        href="javascript:void(0);"
                        class="menu-toggle">

                        <i class="material-icons">
                            inventory
                        </i>

                        <span>
                            Sản phẩm
                        </span>

                    </a>

                    <ul class="ml-menu">

                        <li>

                            <a href="/product">

                                Danh sách sản phẩm

                            </a>

                        </li>

                        <li>

                            <a href="/product/stats">

                                Thống kê sản phẩm

                            </a>

                        </li>

                    </ul>

                </li>

                <!-- CATEGORY -->

                <li>

                    <a href="/category">

                        <i class="material-icons">
                            category
                        </i>

                        <span>
                            Danh mục
                        </span>

                    </a>

                </li>

                <!-- ORDER -->

                <li>

                    <a href="/order">

                        <i class="material-icons">
                            receipt_long
                        </i>

                        <span>
                            Đơn hàng
                        </span>

                    </a>

                </li>

                <!-- RETURN -->
                <li>

                    <a href="/return">

                        <i class="material-icons">
                            swap_horiz
                        </i>

                        <span>
                            Quản lý đổi trả
                        </span>

                    </a>

                </li>

                <!-- NEWS -->
                <li>

                    <a href="/news">

                        <i class="material-icons">
                            article
                        </i>

                        <span>
                            Tin tức
                        </span>

                    </a>

                </li>
                <!-- USER -->

                <li>

                    <a
                        href="javascript:void(0);"
                        class="menu-toggle">

                        <i class="material-icons">
                            people
                        </i>

                        <span>
                            Người dùng
                        </span>

                    </a>

                    <ul class="ml-menu">

                        <li>

                            <a href="/admin-user">

                                Danh sách user

                            </a>

                        </li>

                        <li>

                            <a href="/admin-user?role=USER">

                                USER

                            </a>

                        </li>

                        <li>

                            <a href="/admin-user?role=ADMIN">

                                ADMIN

                            </a>

                        </li>

                    </ul>

                </li>

                <!-- LOGOUT -->

                <li>

                    <a href="/auth/logout">

                        <i class="material-icons">
                            logout
                        </i>

                        <span>
                            Đăng xuất
                        </span>

                    </a>

                </li>

            </ul>

        </div>

    </aside>

</section>

<!-- ================= CONTENT ================= -->

<section class="content">

    <div class="container-fluid">

        <%- body %>

    </div>

</section>

<!-- ================= JS ================= -->

<script src="/plugins/jquery/jquery.min.js"></script>

<script src="/plugins/bootstrap/js/bootstrap.js"></script>

<script src="/plugins/node-waves/waves.js"></script>

<script src="/plugins/jquery-slimscroll/jquery.slimscroll.js"></script>

<script src="/js/admin.js"></script>

<script src="/js/demo.js"></script>

<!-- ================= SUMMERNOTE ================= -->

<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote.min.js"></script>

</body>

</html>