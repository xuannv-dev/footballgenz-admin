﻿﻿﻿<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Admin Panel</title>

    <!-- ================= CSS ================= -->

    <link
        href="/plugins/bootstrap/css/bootstrap.css"
        rel="stylesheet">

    <link
        href="/plugins/node-waves/waves.css"
        rel="stylesheet" />

    <link
        href="/plugins/animate-css/animate.css"
        rel="stylesheet" />

    <link
        href="/css/style.css"
        rel="stylesheet">

    <link
        rel="stylesheet"
        href="/stylesheets/admin.css">

    <!-- ================= ICON ================= -->

    <link
        href="https://fonts.googleapis.com/icon?family=Material+Icons"
        rel="stylesheet">

    <!-- Modern Font: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- ================= SUMMERNOTE ================= -->
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote.min.css">
    <!-- <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote.min.css" integrity="sha256-S97D6f7T3zO92fL9R/fRls96L0T0mX7P+p9p6+rM37Y=" crossorigin="anonymous"> -->

    <!-- ================= CHART ================= -->

    <style>
        :root {
            --primary-color: #4f46e5; /* Indigo-600 */
            --primary-hover: #4338ca;
            --sidebar-bg: #ffffff;
            --sidebar-text: #64748b;
            --sidebar-active: #4f46e5;
            --sidebar-active-bg: #f5f3ff;
            --body-bg: #f8fafc;
            --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            --radius: 12px;
        }

        body {
            font-family: 'Inter', sans-serif !important;
            background-color: var(--body-bg) !important;
            color: #1e293b;
        }

        /* Custom Scrollbar cho hiện đại */
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        /* Style chung cho Buttons để dùng ở cả Login và Dashboard */
        .btn-custom {
            padding: 10px 20px;
            border-radius: var(--radius);
            font-weight: 500;
            transition: all 0.2s;
            border: none;
        }
        .btn-primary-custom {
            background-color: var(--primary-color);
            color: white;
        }
        .btn-primary-custom:hover {
            background-color: var(--primary-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        }

        /* Style cho Inputs */
        .form-control {
            border-radius: 8px !important;
            border: 1px solid #e2e8f0 !important;
            padding: 10px 15px !important;
            transition: all 0.2s !important;
        }
        .form-control:focus {
            border-color: var(--primary-color) !important;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1) !important;
        }

        .navbar {
            background-color: #ffffff !important;
            box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06) !important;
            border: none !important;
        }

        .navbar .navbar-nav > li > a i {
            color: #64748b !important;
        }
        .navbar .navbar-nav > li > a:hover i {
            color: var(--primary-color) !important;
        }

        .navbar-brand {
            color: var(--primary-color) !important;
            font-weight: 700 !important;
            letter-spacing: -0.5px;
        }

        .sidebar {
            background-color: var(--sidebar-bg) !important;
            border-right: 1px solid #e2e8f0;
            box-shadow: none !important;
        }

        .sidebar .menu .list a {
            color: var(--sidebar-text) !important;
            border-radius: 8px;
            margin: 4px 15px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .sidebar .menu .list li.header {
            background: transparent !important;
            color: #94a3b8 !important;
            font-weight: 700;
            font-size: 11px;
            letter-spacing: 0.5px;
        }

        .sidebar .menu .list li.active > a,
        .sidebar .menu .list a:hover {
            background-color: var(--sidebar-active-bg) !important;
            color: var(--sidebar-active) !important;
        }

        .sidebar .menu .list a i {
            font-size: 20px !important;
            margin-top: -2px;
            color: inherit !important;
        }

        .sidebar .user-info {
            background: none !important;
            border-bottom: 1px solid #f1f5f9;
            padding: 20px 15px !important;
            height: auto !important;
        }

        .sidebar .user-info .name {
            color: #1e293b !important;
            font-weight: 600;
        }

        .sidebar .user-info .email {
            color: #64748b !important;
        }

        .content {
            margin-top: 80px !important;
            background-color: var(--body-bg);
        }

        /* Thổi hồn vào các Card chứa nội dung */
        .card {
            border-radius: var(--radius) !important;
            border: none !important;
            box-shadow: var(--card-shadow) !important;
            transition: transform 0.2s;
        }

        /* Auth Page Wrapper (sẽ dùng cho trang login) */
        .auth-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top right, #eef2ff, #f8fafc);
        }

        /* DASHBOARD STAT CARDS */
        .stat-card {
            border-radius: var(--radius);
            padding: 24px;
            color: white;
            position: relative;
            overflow: hidden;
            margin-bottom: 24px;
            min-height: 140px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        .stat-card .icon {
            position: absolute;
            right: -10px;
            bottom: -10px;
            font-size: 80px !important;
            opacity: 0.2;
        }
        .stat-card .number {
            font-size: 28px;
            font-weight: 700;
            margin-top: 8px;
        }
        .stat-card .label {
            font-size: 14px;
            font-weight: 500;
            opacity: 0.9;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .bg-gradient-indigo { background: linear-gradient(135deg, #6366f1 0%, #4338ca 100%); }
        .bg-gradient-emerald { background: linear-gradient(135deg, #10b981 0%, #047857 100%); }
        .bg-gradient-amber { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
        .bg-gradient-rose { background: linear-gradient(135deg, #f43f5e 0%, #be123c 100%); }

        /* CHART WRAPPER */
        .chart-container {
            background: white;
            padding: 20px;
            border-radius: var(--radius);
            box-shadow: var(--card-shadow);
            position: relative;
            margin-bottom: 24px;
        }
    </style>

</head>

<body class="theme-indigo">

<!-- ================= TOPBAR ================= -->

<nav class="navbar">

    <div class="container-fluid">

        <div class="navbar-header">

            <a
                class="navbar-brand"
                href="/admin">

                ⚽ ADMIN FOOTBALL GEN Z

            </a>

        </div>

        <ul class="nav navbar-nav navbar-right">

            <li>

                <a href="/auth/logout">

                    <i class="material-icons">
                        logout
                    </i>

                </a>

            </li>

        </ul>

    </div>

</nav>

<!-- ================= SIDEBAR ================= -->

<section>

    <aside
        id="leftsidebar"
        class="sidebar">

        <!-- USER -->

        <div class="user-info">

            <div class="image">

                <img
                    src="/images/user.png"
                    width="48">

            </div>

            <div class="info-container">

                <div class="name">

                    <%= user
                        ? (user.firstname + ' ' + user.lastname)
                        : 'Admin'
                    %>

                </div>

                <div class="email">

                    <%= user ? user.email : '' %>

                </div>

            </div>

        </div>

        <!-- MENU -->

        <div class="menu">

            <ul class="list">

                <li class="header">
                    QUẢN TRỊ HỆ THỐNG
                </li>

                <!-- DASHBOARD -->

                <li>

                    <a href="/admin">

                        <i class="material-icons">
                            dashboard
                        </i>

                        <span>
                            Dashboard
                        </span>

                    </a>

                </li>

                <!-- PRODUCT -->

                <li>

                    <a
                        href="javascript:void(0);"
                        class="menu-toggle">

                        <i class="material-icons">
                            inventory
                        </i>

                        <span>
                            Sản phẩm
                        </span>

                    </a>

                    <ul class="ml-menu">

                        <li>

                            <a href="/product">

                                Danh sách sản phẩm

                            </a>

                        </li>

                        <li>

                            <a href="/product/stats">

                                Thống kê sản phẩm

                            </a>

                        </li>

                    </ul>

                </li>

                <!-- CATEGORY -->

                <li>

                    <a href="/category">

                        <i class="material-icons">
                            category
                        </i>

                        <span>
                            Danh mục
                        </span>

                    </a>

                </li>

                <!-- ORDER -->

                <li>

                    <a href="/order">

                        <i class="material-icons">
                            receipt_long
                        </i>

                        <span>
                            Đơn hàng
                        </span>

                    </a>

                </li>

                <!-- PAYMENT VERIFICATION -->
                <li>

                    <a href="/admin/payment/pending">

                        <i class="material-icons">
                            payment
                        </i>

                        <span>
                            Xác minh thanh toán
                        </span>

                    </a>

                </li>

                <!-- RETURN -->
                <li>

                    <a href="/return">

                        <i class="material-icons">
                            swap_horiz
                        </i>

                        <span>
                            Quản lý đổi trả
                        </span>

                    </a>

                </li>
                <!-- REVIEW -->
                <li>

                    <a href="/review">

                        <i class="material-icons">
                            reviews
                        </i>

                        <span>
                            Quản lý đánh giá
                        </span>

                    </a>

                </li>
                <!-- NEWS -->
                <li>

                    <a href="/news">

                        <i class="material-icons">
                            article
                        </i>

                        <span>
                            Tin tức
                        </span>

                    </a>

                </li>
                <!-- AUDIT LOG -->
                <li>

                    <a href="/audit-log">

                        <i class="material-icons">
                            history
                        </i>

                        <span>
                            Nhật ký hoạt động
                        </span>

                    </a>

                </li>
                <!-- USER -->

                <li>

                    <a
                        href="javascript:void(0);"
                        class="menu-toggle">

                        <i class="material-icons">
                            people
                        </i>

                        <span>
                            Người dùng
                        </span>

                    </a>

                    <ul class="ml-menu">

                        <li>

                            <a href="/admin-user">

                                Danh sách user

                            </a>

                        </li>

                        <li>

                            <a href="/admin-user?role=USER">

                                USER

                            </a>

                        </li>

                        <li>

                            <a href="/admin-user?role=ADMIN">

                                ADMIN

                            </a>

                        </li>

                    </ul>

                </li>

                <!-- LOGOUT -->

                <li>

                    <a href="/auth/logout">

                        <i class="material-icons">
                            logout
                        </i>

                        <span>
                            Đăng xuất
                        </span>

                    </a>

                </li>

            </ul>

        </div>

    </aside>

</section>

<!-- ================= CONTENT ================= -->

<section class="content">

    <div class="container-fluid">

        <%- body %>

    </div>

</section>

