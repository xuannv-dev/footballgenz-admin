<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>Đăng nhập | Football Genz Admin</title>
    <!-- Favicon-->
    <link rel="icon" href="../../favicon.ico" type="image/x-icon">

    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <!-- CSS Frameworks -->
    <link href="/plugins/bootstrap/css/bootstrap.css" rel="stylesheet">
    <link href="/plugins/node-waves/waves.css" rel="stylesheet" />
    <link href="/plugins/animate-css/animate.css" rel="stylesheet" />

    <!-- Google reCAPTCHA -->
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>

    <style>
        :root {
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --body-bg: #f8fafc;
            --card-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            --radius: 12px;
        }

        body.login-page {
            font-family: 'Inter', sans-serif !important;
            background: radial-gradient(circle at top right, #eef2ff, #f8fafc);
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
        }

        .login-box {
            width: 400px;
            margin: 20px;
        }

        .login-box .logo h2 {
            color: var(--primary-color) !important;
            font-weight: 800;
            letter-spacing: -1px;
            text-transform: uppercase;
            margin-bottom: 0;
        }

        .login-box .logo small {
            color: #64748b;
            font-weight: 500;
        }

        .card {
            background: #ffffff;
            border-radius: var(--radius) !important;
            border: none !important;
            box-shadow: var(--card-shadow) !important;
            margin-top: 30px;
            overflow: hidden;
        }

        .card .body {
            padding: 40px !important;
        }

        .msg {
            color: #1e293b;
            font-weight: 600;
            font-size: 16px;
            margin-bottom: 25px !important;
            text-align: center;
        }

        .input-group {
            margin-bottom: 20px !important;
            border-radius: 8px;
            background: #f1f5f9;
            padding: 5px 15px;
            border: 1px solid transparent;
            transition: all 0.3s;
        }

        .input-group.focused {
            border-color: var(--primary-color);
            background: #fff;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1);
        }

        .input-group-addon {
            background: transparent !important;
            border: none !important;
            padding-right: 10px !important;
        }

        .input-group-addon i {
            color: #94a3b8 !important;
            font-size: 20px !important;
        }

        .form-control {
            background: transparent !important;
            border: none !important;
            box-shadow: none !important;
            height: 40px !important;
            color: #1e293b !important;
            font-weight: 500;
        }

        .btn-login {
            background-color: var(--primary-color) !important;
            color: white !important;
            font-weight: 600 !important;
            font-size: 15px !important;
            padding: 12px !important;
            border-radius: 8px !important;
            letter-spacing: 0.5px;
            transition: all 0.3s;
            border: none;
            width: 100%;
            display: block;
        }

        .btn-login:hover {
            background-color: var(--primary-hover) !important;
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.4);
        }

        .auth-links a {
            color: #64748b;
            font-weight: 500;
            font-size: 13px;
            text-decoration: none;
            transition: color 0.2s;
        }

        .auth-links a:hover {
            color: var(--primary-color);
        }

        .text-danger {
            background: #fef2f2;
            color: #dc2626;
            padding: 10px;
            border-radius: 6px;
            font-size: 13px;
            text-align: center;
            margin-top: 15px;
            border: 1px solid #fee2e2;
        }
    </style>
</head>

<body class="login-page">
    <div class="login-box">
        <div class="logo text-center">
            <h2>FOOTBALL GEN Z</h2>
            <small>Hệ thống quản trị thương mại điện tử</small>
        </div>
        <div class="card">
            <div class="body">
                <form id="sign_in" method="POST">
                    <div class="msg">Chào mừng trở lại!</div>
                    <div class="input-group">
                        <span class="input-group-addon">
                            <i class="material-icons">email</i>
                        </span>
                        <input type="email" class="form-control" name="email" placeholder="Địa chỉ Email" required autofocus>
                    </div>
                    <div class="input-group">
                        <span class="input-group-addon">
                            <i class="material-icons">lock</i>
                        </span>
                        <input type="password" class="form-control" name="password" placeholder="Mật khẩu" required>
                    </div>
                    <!-- 
                    <div class="m-b-20 text-center">
                        <div class="g-recaptcha" style="display: inline-block;" data-sitekey="6LejvhEtAAAAALhdnnHLyuIGk6WIiaDHviiWM5AV"></div>
                    </div> 
                    -->
                    <div class="row m-t-15">
                        <div class="col-xs-12">
                            <input type="checkbox" name="rememberme" id="rememberme" class="filled-in chk-col-indigo">
                            <label for="rememberme" style="color: #64748b; font-weight: 500; cursor: pointer;">Ghi nhớ đăng nhập</label>
                        </div>
                        <div class="col-xs-12 m-t-15">
                            <button class="btn btn-login waves-effect" type="submit">ĐĂNG NHẬP</button>
                        </div>
                    </div>
                    <% if (messages.error && messages.error.length > 0) { %>
                        <p class="text-danger"><%= messages.error %></p>
                    <% } %>
                    <% if (messages.message && messages.message.length > 0) { %>
                        <p class="text-success"><%= messages.message %></p>
                    <%}%>
                    <div class="row m-t-25 auth-links">
                        <div class="col-xs-6">
                            <a href="/auth/register">Đăng ký ngay!</a>
                        </div>
                        <div class="col-xs-6 align-right">
                            <a href="/auth/forgot-password">Quên mật khẩu?</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="/plugins/jquery/jquery.min.js"></script>
    <script src="/plugins/bootstrap/js/bootstrap.js"></script>
    <script src="/plugins/node-waves/waves.js"></script>
    <script src="/plugins/jquery-validation/jquery.validate.js"></script>
    <script>
        $(function () {
            $('.input-group input').focus(function () {
                $(this).parent().addClass('focused');
            }).blur(function () {
                $(this).parent().removeClass('focused');
            });
        });
    </script>
</body>
</html>