<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <title>Quên mật khẩu Admin | Football Genz</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link href="/plugins/bootstrap/css/bootstrap.css" rel="stylesheet">
    <link href="/plugins/node-waves/waves.css" rel="stylesheet" />
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <style>
        body.login-page { font-family: 'Inter', sans-serif !important; background: radial-gradient(circle at top right, #eef2ff, #f8fafc); display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
        .login-box { width: 400px; }
        .card { background: #ffffff; border-radius: 12px !important; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1) !important; border: none; overflow: hidden; }
        .card .body { padding: 40px !important; }
        .msg { font-weight: 600; text-align: center; margin-bottom: 25px; }
        .input-group { margin-bottom: 20px !important; background: #f1f5f9; padding: 5px 15px; border-radius: 8px; border: 1px solid transparent; display: flex; align-items: center; }
        .form-control { background: transparent !important; border: none !important; box-shadow: none !important; }
        .btn-reset { background-color: #4f46e5 !important; color: white !important; width: 100%; padding: 12px; border-radius: 8px; border: none; font-weight: 600; }
        .text-danger { color: #dc2626; font-size: 13px; text-align: center; margin-bottom: 15px; }
        .loader-spin { display: none; margin-left: 8px; animation: spin 1s infinite linear; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    </style>
</head>
<body class="login-page">
    <div class="login-box">
        <div class="card">
            <div class="body">
                <form id="forgot_password" method="POST">
                    <div class="msg">KHÔI PHỤC MẬT KHẨU ADMIN</div>
                    <p class="text-center text-muted m-b-20" style="font-size: 13px;">Nhập email Admin để nhận mật khẩu mới trực tiếp.</p>
                    
                    <% if(typeof error !="undefined"){%>
                        <div class="text-danger"><%=error%></div>
                    <%}%>

                    <div class="input-group">
                        <span class="input-group-addon"><i class="material-icons">email</i></span>
                        <input type="email" class="form-control" name="email" placeholder="Email Admin" required autofocus>
                    </div>

                    <div class="m-b-20 text-center">
                        <div class="g-recaptcha" style="display: inline-block;" data-sitekey="6LejvhEtAAAAALhdnnHLyuIGk6WIiaDHviiWM5AV"></div>
                    </div>

                    <button class="btn btn-reset waves-effect" type="submit" id="btnSubmit">
                        <span class="btn-text">GỬI YÊU CẦU</span>
                        <i class="material-icons loader-spin">sync</i>
                    </button>

                    <div class="row m-t-20">
                        <div class="col-xs-12 text-center">
                            <a href="/auth/login" style="text-decoration: none; color: #64748b; font-size: 13px;">Quay lại đăng nhập</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="/plugins/jquery/jquery.min.js"></script>
    <script>
        $('#forgot_password').on('submit', function() {
            var btn = $('#btnSubmit');
            btn.prop('disabled', true);
            btn.find('.btn-text').text('ĐANG XỬ LÝ...');
            btn.find('.loader-spin').show();
        });
    </script>
</body>
</html>
