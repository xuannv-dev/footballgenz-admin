<div class="row clearfix">

    <!-- TOTAL REVENUE -->
    <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
        <div class="stat-card bg-gradient-indigo">
            <div class="label">Tổng doanh thu</div>
            <div class="number"><%= totalRevenue.toLocaleString('vi-VN') %>₫</div>
            <i class="material-icons icon">attach_money</i>
        </div>
    </div>

    <!-- TODAY ORDERS -->
    <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
        <div class="stat-card bg-gradient-emerald">
            <div class="label">Đơn hàng hôm nay</div>
            <div class="number"><%= todayOrders %></div>
            <i class="material-icons icon">today</i>
        </div>
    </div>

    <!-- TOTAL PRODUCT -->
    <div class="col-lg-4 col-md-4 col-sm-6 col-xs-12">
        <div class="stat-card bg-gradient-rose">
            <div class="label">Tổng sản phẩm</div>
            <div class="number"><%= totalProducts %></div>
            <i class="material-icons icon">inventory</i>
        </div>
    </div>
</div>

<div class="row clearfix">

    <!-- TOTAL USER -->

    <div class="col-lg-3 col-md-3 col-sm-6 col-xs-12">
        <div class="stat-card" style="background: linear-gradient(135deg, #64748b 0%, #334155 100%);">
            <div class="label">Người dùng</div>
            <div class="number"><%= totalCustomers %></div>
            <i class="material-icons icon">people</i>
        </div>
    </div>

    <!-- TOTAL ORDER -->

    <div class="col-lg-3 col-md-3 col-sm-6 col-xs-12">
        <div class="stat-card bg-gradient-amber">
            <div class="label">Đơn hàng</div>
            <div class="number"><%= totalOrders %></div>
            <i class="material-icons icon">receipt_long</i>
        </div>
    </div>

    <!-- TOTAL NEWS -->

    <div class="col-lg-3 col-md-3 col-sm-6 col-xs-12">
        <div class="stat-card bg-gradient-rose">
            <div class="label">Bài viết</div>
            <div class="number"><%= totalNews %></div>
            <i class="material-icons icon">article</i>
        </div>
    </div>

</div>

<div class="row clearfix">
    <div class="col-lg-8">
        <div class="chart-container">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h4 style="font-weight: 600; color: #1e293b; margin: 0;">📈 Doanh thu theo tháng</h4>
                <button type="button" class="btn btn-success waves-effect btn-xs" id="btnExportExcel">
                    <i class="material-icons" style="font-size: 18px; vertical-align: middle;">file_download</i>
                    Xuất Excel
                </button>
            </div>
            <div style="height: 320px; position: relative;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-container">
            <h4 class="m-b-20" style="font-weight: 600; color: #1e293b;">📊 7 ngày gần nhất</h4>
            <div style="height: 320px; position: relative;">
                <canvas id="dashboardChart"></canvas>
            </div>
        </div>
    </div>
</div>
<!-- ================= CONTENT ================= -->

<div class="row clearfix">


    <!-- LEFT -->
    <div class="col-lg-8">

        <!-- RECENT ORDER -->
        <div class="card">

            <div class="header">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <h2 style="margin: 0;">🧾 ĐƠN HÀNG GẦN ĐÂY</h2>
                    <button type="button" class="btn btn-primary waves-effect btn-xs" id="btnExportRecentOrders">
                        <i class="material-icons" style="font-size: 18px; vertical-align: middle;">file_download</i>
                        Xuất Excel
                    </button>
                </div>
            </div>

            <div class="body">

                <div class="table-responsive">

                    <table class="table table-bordered table-hover">

                        <thead>
                            <tr>
                                <th>Mã đơn</th>
                                <th>Khách</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>

                        <tbody>

                            <% recentOrders.forEach(order => { %>

                                <tr>

                                    <td>
                                        <%= order.code %>
                                    </td>

                                    <td>
                                        <%= order.receiver %>
                                    </td>

                                    <td>
                                        <%= order.totalprice.toLocaleString('vi-VN') %>₫
                                    </td>

                                    <td>

                                        <% if(order.status == 0){ %>
                                            <span class="label bg-red">Đã hủy</span>
                                        <% } %>

                                        <% if(order.status == 1){ %>
                                            <span class="label bg-blue">Tiếp nhận</span>
                                        <% } %>

                                        <% if(order.status == 2){ %>
                                            <span class="label bg-orange">Chuẩn bị</span>
                                        <% } %>

                                        <% if(order.status == 3){ %>
                                            <span class="label bg-cyan">Đang giao</span>
                                        <% } %>

                                        <% if(order.status == 4){ %>
                                            <span class="label bg-green">Hoàn thành</span>
                                        <% } %>

                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <!-- RIGHT -->
    <div class="col-lg-4">

        <!-- TOP SELLING -->
        <div class="card">

            <div class="header">
                <h2>🔥 TOP BÁN CHẠY</h2>
            </div>

            <div class="body">

                <table class="table table-bordered">

                    <thead>
                        <tr>
                            <th>Mã SP</th>
                            <th>Đã bán</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% topSelling.forEach(item => { %>

                            <tr>

                                <td>
                                    <%= item._id %>
                                </td>

                                <td>
                                    <%= item.sold %>
                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

        <!-- LOW STOCK -->
        <div class="card">

            <div class="header">
                <h2>⚠️ SẮP HẾT HÀNG</h2>
            </div>

            <div class="body">

                <table class="table table-bordered">

                    <thead>
                        <tr>
                            <th>Tên SP</th>
                            <th>Tồn kho</th>
                        </tr>
                    </thead>

                    <tbody>

                        <% lowStockProducts.forEach(p => { %>

                            <tr>

                                <td>
                                    <%= p.name %>
                                </td>

                                <td>
                                    <%= Math.min(...p.variants.map(v => v.stock)) %>
                                </td>

                            </tr>

                        <% }) %>

                    </tbody>

                </table>

            </div>

        </div>

    </div>
    
</div>
<script>
document.addEventListener('DOMContentLoaded', function(){
    // Đảm bảo XLSX đã sẵn sàng
    const XLSX = window.XLSX;

    const rawRecentOrders = <%- JSON.stringify(recentOrders || []) %>;
    const raw7Days = <%- JSON.stringify(last7Days || []) %>;
    const rawMonth = <%- JSON.stringify(monthlyRevenue || []) %>;

    // ===== BIỂU ĐỒ 1: DOANH THU 7 NGÀY GẦN NHẤT (CỘT) =====
    const ctxDash = document.getElementById('dashboardChart');
    new Chart(ctxDash, {
        type: 'bar',
        data: {
            labels: raw7Days.map(item => item._id.day + '/' + item._id.month),
            datasets: [{
                label: 'Doanh thu (₫)',
                data: raw7Days.map(item => item.total),
                backgroundColor: '#29b6f6',
                borderRadius: 8
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    ticks: {
                        callback: (val) => val.toLocaleString('vi-VN') + '₫'
                    }
                }
            }
        }
    });

    // ===== BIỂU ĐỒ 2: DOANH THU THEO THÁNG (ĐƯỜNG) =====
    const ctxRev = document.getElementById('revenueChart').getContext('2d');
    const gradient = ctxRev.createLinearGradient(0, 0, 0, 400);
    gradient.addColorStop(0, 'rgba(79, 70, 229, 0.4)');
    gradient.addColorStop(1, 'rgba(79, 70, 229, 0)');

    new Chart(ctxRev, {
        type: 'line',
        data: {
            labels: rawMonth.map(item => 'Tháng ' + item._id.month),
            datasets: [{
                label: 'Doanh thu',
                data: rawMonth.map(item => item.total),
                backgroundColor: gradient,
                borderColor: '#4f46e5',
                borderWidth: 3,
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: '#4f46e5'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                tooltip: {
                    padding: 12,
                    backgroundColor: 'rgba(30, 41, 59, 0.9)',
                    cornerRadius: 8
                }
            },
            scales: {
                y: {
                    ticks: {
                        callback: (val) => val.toLocaleString('vi-VN') + '₫'
                    }
                }
            }
        }
    });

    // Hàm trợ giúp để áp dụng các kiểu dáng cơ bản cho worksheet
    function applyBasicTableStyles(worksheet, columnWidths) {
        const range = window.XLSX.utils.decode_range(worksheet['!ref']);

        // Style cho hàng tiêu đề (header)
        for (let C = range.s.c; C <= range.e.c; ++C) {
            const cellref = window.XLSX.utils.encode_cell({ r: 0, c: C });
            if (!worksheet[cellref]) continue;
            worksheet[cellref].s = {
                font: { bold: true, color: { rgb: "FFFFFFFF" } }, // Chữ trắng, in đậm
                fill: { fgColor: { rgb: "FF4F46E5" } }, // Nền màu indigo (primary color)
                alignment: { horizontal: "center", vertical: "center" },
                border: {
                    top: { style: "thin", color: { auto: 1 } },
                    bottom: { style: "thin", color: { auto: 1 } },
                    left: { style: "thin", color: { auto: 1 } },
                    right: { style: "thin", color: { auto: 1 } }
                }
            };
        }

        // Áp dụng viền cho tất cả các ô dữ liệu
        for (let R = range.s.r; R <= range.e.r; ++R) {
            for (let C = range.s.c; C <= range.e.c; ++C) {
                const cellref = window.XLSX.utils.encode_cell({ r: R, c: C });
                if (!worksheet[cellref]) continue;
                if (!worksheet[cellref].s) worksheet[cellref].s = {}; // Khởi tạo style nếu chưa có
                worksheet[cellref].s.border = {
                    top: { style: "thin", color: { auto: 1 } },
                    bottom: { style: "thin", color: { auto: 1 } },
                    left: { style: "thin", color: { auto: 1 } },
                    right: { style: "thin", color: { auto: 1 } }
                };

                // Định dạng tiền tệ cho cột "Doanh thu (VNĐ)" và "Tổng tiền (VNĐ)"
                // Cần xác định cột nào là cột tiền tệ dựa vào tiêu đề hoặc vị trí
                if (worksheet[XLSX.utils.encode_cell({ r: 0, c: C })].v === 'Doanh thu (VNĐ)' ||
                    worksheet[XLSX.utils.encode_cell({ r: 0, c: C })].v === 'Tổng tiền (VNĐ)') {
                    worksheet[cellref].t = 'n'; // Set type to number
                    worksheet[cellref].z = '#,##0 "₫"'; // Custom number format for currency
                }
            }
        }

        // Thiết lập độ rộng cột
        if (columnWidths) {
            worksheet['!cols'] = columnWidths;
        }
    }

    // Logic xử lý xuất file Excel
    document.getElementById('btnExportExcel').addEventListener('click', function() {
        if (!rawMonth || rawMonth.length === 0) {
            return alert('Không có dữ liệu doanh thu để xuất!');
        }

        // Chuẩn bị dữ liệu: Map lại các field để hiển thị tiêu đề tiếng Việt đẹp trong Excel
        const dataToExport = rawMonth.map(item => ({
            'Tháng': 'Tháng ' + item._id.month,
            'Doanh thu (VNĐ)': item.total
        }));

        const worksheet = window.XLSX.utils.json_to_sheet(dataToExport, { header: ['Tháng', 'Doanh thu (VNĐ)'] });
        const columnWidths = [{ wch: 15 }, { wch: 25 }]; // Độ rộng cho cột Tháng và Doanh thu
        applyBasicTableStyles(worksheet, columnWidths);

        const workbook = window.XLSX.utils.book_new();
        window.XLSX.utils.book_append_sheet(workbook, worksheet, "Doanh Thu");
        window.XLSX.writeFile(workbook, "Bao_cao_doanh_thu_thang.xlsx");
    });

    // Logic xuất danh sách đơn hàng gần đây
    document.getElementById('btnExportRecentOrders').addEventListener('click', function() {
        if (!rawRecentOrders || rawRecentOrders.length === 0) {
            return alert('Không có đơn hàng nào để xuất!');
        }

        const statusMap = {
            0: 'Đã hủy',
            1: 'Tiếp nhận',
            2: 'Chuẩn bị',
            3: 'Đang giao',
            4: 'Hoàn thành'
        };

        // Map dữ liệu sang định dạng tiếng Việt và bao gồm thông tin khách hàng
        const dataToExport = rawRecentOrders.map(order => ({
            'Mã đơn hàng': order.code,
            'Tên khách hàng': order.receiver,
            'Số điện thoại': order.phoneContact || 'N/A',
            'Địa chỉ giao hàng': order.addressShip || 'N/A',
            'Tổng tiền (VNĐ)': order.totalprice,
            'Trạng thái': statusMap[order.status] || 'Không xác định',
            'Ngày tạo': new Date(order.createdAt).toLocaleString('vi-VN')
        }));

        const worksheet = window.XLSX.utils.json_to_sheet(dataToExport, { header: ['Mã đơn hàng', 'Tên khách hàng', 'Số điện thoại', 'Địa chỉ giao hàng', 'Tổng tiền (VNĐ)', 'Trạng thái', 'Ngày tạo'] });
        const columnWidths = [{ wch: 15 }, { wch: 25 }, { wch: 20 }, { wch: 40 }, { wch: 20 }, { wch: 15 }, { wch: 25 }]; // Độ rộng cho các cột đơn hàng
        applyBasicTableStyles(worksheet, columnWidths);

        const workbook = window.XLSX.utils.book_new();
        window.XLSX.utils.book_append_sheet(workbook, worksheet, "Đơn hàng gần đây");
        window.XLSX.writeFile(workbook, "Danh_sach_don_hang_gan_day.xlsx");
    });
});
</script>