<div class="card">

    <!-- <div class="header">
        <h2>📁 CHI TIẾT DANH MỤC</h2>
        <a href="/category" class="btn btn-secondary">← Quay lại</a>
    </div> -->

    <div class="body">

        <!-- NAME -->
        <div class="form-group">
            <label>Tên danh mục (Hiển thị cho khách hàng) *</label>

            <div class="form-line">
                <input
                    type="text"
                    id="name"
                    class="form-control"
                    value="<%= category.name || '' %>"
                    required
                >
            </div>
        </div>

        <!-- GROUP -->
        <div class="form-group">
            <label>Mã danh mục (Liên kết với Sản phẩm) *</label>

            <div class="form-line">
                <input
                    type="text"
                    id="group"
                    class="form-control"
                    value="<%= category.group %>"
                    required
                >
            </div>
        </div>

        <!-- TYPE -->
        <div class="form-group">
            <label>Loại (nhập từng loại, cách bằng dấu phẩy) *</label>

            <div class="form-line">
                <input
                    type="text"
                    id="type"
                    class="form-control"
                    value="<%= Array.isArray(category.type) ? category.type.join(', ') : category.type %>"
                    placeholder="VD: Giày đá bóng, Giày futsal, Giày đào tạo"
                    required
                >
            </div>
            <small class="form-text text-muted">Nhập các loại cách nhau bằng dấu phẩy</small>
        </div>

        <!-- STATUS -->
        <div class="form-group">
            <label>Trạng thái</label>

            <select id="isActive" class="form-control">
                <option value="true" <%= category.isActive == true ? 'selected' : '' %>>
                    Hoạt động
                </option>
                <option value="false" <%= category.isActive == false ? 'selected' : '' %>>
                    Tạm khóa
                </option>
            </select>
        </div>

        <!-- IMAGE -->
        <div class="form-group">
            <label>Ảnh danh mục</label>

            <div style="margin-bottom: 15px;">
                <img
                    id="previewImage"
                    src="<%= category.image || '/images/no-image.jpg' %>"
                    style="width: 120px; height: 120px; border-radius: 8px; border: 1px solid #e5e7eb;"
                >
            </div>

            <input type="hidden" id="image" value="<%= category.image %>">

            <div class="form-line">
                <input type="file" id="fileUpload" accept="image/*">
            </div>

            <button
                type="button"
                class="btn btn-info"
                id="btnUpload"
                style="margin-top: 10px;"
            >
                📤 Upload ảnh
            </button>
        </div>

        <!-- BUTTONS -->
        <div style="margin-top: 24px; display: flex; gap: 12px;">
            <button
                class="btn btn-primary"
                onclick="updateCategory()"
            >
                ✅ Cập nhật danh mục
            </button>
            <a href="/category" class="btn btn-secondary">
                Quay lại
            </a>
        </div>

    </div>

</div>

<script>
// Upload image
document.getElementById('btnUpload').addEventListener('click', async function() {
    const file = document.getElementById('fileUpload').files[0];
    let thumbnailUrl =
        '<%= category.image %>';
    if (!file) {
        alert("Vui lòng chọn ảnh");
        return;
    }

    const formData = new FormData();
    formData.append("file", file);
    
    // Lấy tên danh mục hiện tại để tạo thư mục lưu ảnh
    const groupName = document.getElementById('group').value.trim() || 'KHAC';
    formData.append("group", 'CATEGORY/' + groupName);

    try {
        const response = await fetch("/upload", {
            method: "POST",
            body: formData
        });
        const result =
                await response.json();

            if(result.success){

                thumbnailUrl =
                    result.url;

                $('#previewImage').attr(
                    'src',
                    result.url
                );

                alert(
                    'Upload ảnh thành công'
                );

            }else{

                alert(
                    'Upload ảnh thất bại'
                );

            }

        // const imageUrl = await response.text();
        document.getElementById('image').value = thumbnailUrl;
        document.getElementById('fileUpload').value = '';

        alert("✅ Upload ảnh thành công!");
    } catch (error) {
        console.error('Error:', error);
        alert("❌ Upload ảnh thất bại!");
    }
});

// Update category
async function updateCategory() {
    const name = document.getElementById('name').value.trim();
    const group = document.getElementById('group').value.trim();
    const typeStr = document.getElementById('type').value.trim();
    const image = document.getElementById('image').value;
    const isActive = document.getElementById('isActive').value === 'true';

    if (!name || !group) {
        alert("Tên danh mục và Mã nhóm không được để trống!");
        return;
    }

    if (!typeStr) {
        alert("Loại không được để trống!");
        return;
    }

    // Convert comma-separated string to array
    const type = typeStr.split(',').map(t => t.trim()).filter(t => t);

    if (type.length === 0) {
        alert("Loại không được để trống!");
        return;
    }

    try {
        const response = await fetch("/category/update/<%= category._id %>", {
            method: "PUT",
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                name,
                group,
                type,
                image,
                isActive
            })
        });

        if (!response.ok) {
            throw new Error('Update failed');
        }

        alert("✅ Cập nhật danh mục thành công!");
        window.location.href = '/category';
    } catch (error) {
        console.error('Error:', error);
        alert("❌ Cập nhật thất bại!");
    }
}

// Handle Enter key in inputs
document.getElementById('name').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') updateCategory();
});

document.getElementById('group').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') updateCategory();
});

document.getElementById('type').addEventListener('keypress', function(e) {
    if (e.key === 'Enter') updateCategory();
});
</script>