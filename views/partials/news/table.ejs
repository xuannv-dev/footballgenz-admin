<div class="row clearfix">

    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

        <div class="card">

            <!-- ================= HEADER ================= -->

            <div class="header">

                <h2>
                    📰 DANH SÁCH TIN TỨC
                </h2>

            </div>

            <!-- ================= FILTER ================= -->

            <div
                style="
                    margin:15px;
                    display:flex;
                    gap:10px;
                    flex-wrap:wrap;
                    align-items:center;
                ">

                <!-- KEYWORD -->

                <input

                    type="text"

                    id="keyword"

                    value="<%= keyword || '' %>"

                    placeholder="🔍 Tìm tiêu đề..."

                    class="form-input"

                    style="width:250px;"
                >

                <%- include('../shared/date-filter', { fromDate, toDate }) %>

                <!-- SEARCH -->

                <button
                    class="btn-main"
                    onclick="searchNews()">

                    Tìm

                </button>

                <!-- ADD -->

                <a
                    href="/news/add"
                    class="btn btn-success">

                    <i class="material-icons">
                        add
                    </i>

                    Thêm bài viết

                </a>

            </div>

            <!-- ================= TABLE ================= -->

            <div class="body">

                <div class="table-responsive">

                    <table
                        class="table table-bordered table-hover dataTable">

                        <thead
                            style="text-align:center;">

                            <tr>

                                <th>Thumbnail</th>

                                <th>Tiêu đề</th>

                                <th>Mô tả</th>

                                <th>Trạng thái</th>

                                <th class="col-sm-3">
                                    Hành động
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <% news.forEach(function(n){ %>

                                <tr>

                                    <!-- THUMBNAIL -->

                                    <td
                                        style="
                                            width:100px;
                                            text-align:center;
                                            vertical-align:middle;
                                        ">

                                        <img

                                            src="<%= n.thumbnail
                                                || '/images/no-image.jpg'
                                            %>"

                                            width="80"

                                            height="80"

                                            style="
                                                object-fit:cover;
                                                border-radius:8px;
                                                border:1px solid #ddd;
                                            "
                                        >

                                    </td>

                                    <!-- TITLE -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                            font-weight:bold;
                                        ">

                                        <%= n.title %>

                                    </td>

                                    <!-- DESCRIPTION -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                        ">

                                        <%= n.description %>

                                    </td>

                                    <!-- STATUS -->

                                    <td
                                        style="
                                            text-align:center;
                                            vertical-align:middle;
                                        ">

                                        <% if(n.isActive){ %>

                                            <span
                                                class="badge bg-green">

                                                Hiển thị

                                            </span>

                                        <% } else { %>

                                            <span
                                                class="badge bg-grey">

                                                Ẩn

                                            </span>

                                        <% } %>

                                    </td>

                                    <!-- ACTION -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                        ">

                                        <div
                                            style="
                                                display:flex;
                                                gap:5px;
                                                flex-wrap:wrap;
                                            ">

                                            <!-- DETAIL -->

                                            <a

                                                href="/news/detail/<%= n.slug %>"

                                                class="btn btn-info btn-sm">

                                                Chi tiết

                                            </a>

                                            <!-- EDIT -->

                                            <a

                                                href="/news/edit/<%= n.slug %>"

                                                class="btn btn-primary btn-sm">

                                                Sửa

                                            </a>

                                            <!-- DELETE -->

                                            <% if(n.isActive){ %>

                                                <a

                                                    href="/news/delete/<%= n.slug %>"

                                                    class="btn btn-danger btn-sm"

                                                    onclick="return confirm('Xác nhận ẩn bài viết?')">

                                                    Ẩn

                                                </a>

                                            <% } else { %>

                                                <a

                                                    href="/news/active/<%= n.slug %>"

                                                    class="btn btn-success btn-sm">

                                                    Hiển thị

                                                </a>

                                            <% } %>

                                        </div>

                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- ================= PAGINATION ================= -->

<div class="row clearfix">

    <% if(pages > 0) { %>

        <ul class="pagination mx-auto">

            <!-- FIRST -->

            <li
                class="page-item <%= current == 1 ? 'disabled' : '' %>">

                <a

                    class="page-link"

                    href="/news?page=1<%= queryString ? '&' + queryString : '' %>">

                    First

                </a>

            </li>

            <!-- PAGE NUMBER -->

            <% for(let i = 1; i <= pages; i++){ %>

                <li
                    class="page-item <%= current == i ? 'active' : '' %>">

                    <a

                        class="page-link"

                        href="/news?page=<%= i %><%= queryString ? '&' + queryString : '' %>">

                        <%= i %>

                    </a>

                </li>

            <% } %>

            <!-- LAST -->

            <li
                class="page-item <%= current == pages ? 'disabled' : '' %>">

                <a

                    class="page-link"

                    href="/news?page=<%= pages %><%= queryString ? '&' + queryString : '' %>">

                    Last

                </a>

            </li>

        </ul>

    <% } %>

</div>

<!-- ================= SCRIPT ================= -->

<script>

function searchNews(){

    const keyword =
        document.getElementById(
            'keyword'
        ).value;

    const params =
        appendAdminDateParams(
            new URLSearchParams()
        );

    if(!params){
        return;
    }

    if(keyword){
        params.set('keyword', keyword);
    }

    window.location.href =
        `/news?${params.toString()}`;

}

</script>
