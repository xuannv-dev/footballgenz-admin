<div class="row clearfix">

    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

        <div class="card">

            <!-- ================= HEADER ================= -->

            <div class="header">

                <h2>
                    ✏️ CẬP NHẬT BÀI VIẾT
                </h2>

            </div>

            <!-- ================= BODY ================= -->

            <div class="body">

                <!-- TITLE -->

                <div class="form-group">

                    <label>
                        Tiêu đề
                    </label>

                    <input

                        type="text"

                        id="title"

                        class="form-control"

                        value="<%= news.title %>"
                    >

                </div>

                <!-- SLUG -->

                <div class="form-group">

                    <label>
                        Đường dẫn bài viết
                    </label>

                    <input

                        type="text"

                        id="slug"

                        class="form-control"

                        value="<%= news.slug %>"
                    >

                </div>

                <!-- STATUS -->

                <div class="form-group">

                    <label>
                        Trạng thái
                    </label>

                    <select
                        id="isActive"
                        class="form-control order-status-select">

                        <option
                            value="true"
                            <%= news.isActive ? 'selected' : '' %>>

                            Hiển thị

                        </option>

                        <option
                            value="false"
                            <%= !news.isActive ? 'selected' : '' %>>

                            Ẩn

                        </option>

                    </select>

                </div>

                <!-- THUMBNAIL -->

                <div class="form-group">

                    <label>
                        Thumbnail
                    </label>

                    <div style="margin-bottom:15px;">

                            <img
                                id="preview"
                                src="<%= news.thumbnail || '/images/no-image.jpg' %>"
                                width="180"
                                style="
                                    border-radius:8px;
                                    border:1px solid #ddd;
                                "
                            >

                        </div>

                        <input
                            type="hidden"
                            id="thumbnail"
                            value="<%= news.thumbnail %>"
                        >

                        <div class="form-line">

                            <input
                                type="file"
                                id="thumbnailFile"
                                accept="image/*"
                            >

                        </div>

                        <button
                            type="button"
                            class="btn btn-info"
                            id="btnUploadThumbnail"
                            style="margin-top:10px;"
                        >
                            📤 Upload ảnh
                        </button>

                </div>

                <!-- DESCRIPTION -->

                <div class="form-group">

                    <label>
                        Mô tả ngắn
                    </label>

                    <textarea

                        id="description"

                        class="form-control"

                        rows="3"><%= news.description %></textarea>

                </div>

                <!-- CONTENT -->

                <div class="form-group">

                    <label>
                        Nội dung
                    </label>

                    <textarea
                        id="content"><%- news.content %></textarea>

                </div>

                <!-- BUTTON -->

                <button
                    class="btn btn-primary"
                    id="btnUpdateNews">

                    Cập nhật bài viết

                </button>

                <a

                    href="/news"

                    class="btn btn-default">

                    Quay lại

                </a>

            </div>

        </div>

    </div>

</div>

<!-- ================= SCRIPT ================= -->

<script>

window.addEventListener('load', function(){

    let thumbnailUrl =
        '<%= news.thumbnail %>';

    // ================= SUMMERNOTE =================

    $('#content').summernote({

        height: 300,

        placeholder: 'Nhập nội dung bài viết...'

    });

    // ================= AUTO SLUG =================

    $('#title').on('keyup', function(){

        let slug =
            $(this).val()

            .toLowerCase()

            .normalize("NFD")

            .replace(/[\u0300-\u036f]/g, "")

            .replace(/đ/g, "d")

            .replace(/[^a-z0-9 ]/g, '')

            .replace(/\s+/g, '-');

        $('#slug').val(slug);

    });

    // ================= UPLOAD THUMBNAIL =================

    document
        .getElementById('btnUploadThumbnail')
        .addEventListener(
            'click',
            async function(){

                const file =
                    document
                    .getElementById(
                        'thumbnailFile'
                    )
                    .files[0];

                if(!file){

                    alert(
                        'Vui lòng chọn ảnh'
                    );

                    return;

                }

                if(
                    file.size >
                    10 * 1024 * 1024
                ){

                    alert(
                        'Ảnh vượt quá 10MB'
                    );

                    return;

                }

                const formData =
                    new FormData();

                formData.append(
                    'file',
                    file
                );

                formData.append(
                    'group',
                    'news'
                );

                try{

                    const response =
                        await fetch(
                            '/upload',
                            {
                                method:'POST',
                                body:formData
                            }
                        );

                    if(!response.ok){

                        const text =
                            await response.text();

                        throw new Error(text);

                    }

                    const imageUrl =
                        await response.text();

                    thumbnailUrl =
                        imageUrl;

                    document
                    .getElementById(
                        'thumbnail'
                    ).value =
                        imageUrl;

                    document
                    .getElementById(
                        'preview'
                    ).src =
                        imageUrl;

                    alert(
                        'Upload ảnh thành công'
                    );

                }
                catch(error){

                    console.log(error);

                    alert(
                        'Upload ảnh thất bại'
                    );

                }

            }
        );

    // ================= UPDATE NEWS =================

    $('#btnUpdateNews').click(async function(){

        const data = {

            title:
                $('#title').val(),

            slug:
                $('#slug').val(),

            thumbnail:
                thumbnailUrl,

            description:
                $('#description').val(),

            content:
                $('#content')
                    .summernote('code'),

            isActive:
                $('#isActive').val()

        };

        // ================= VALIDATION =================

        if(!data.title){

            alert(
                'Vui lòng nhập tiêu đề'
            );

            return;

        }

        try{

            const response =
                await fetch(

                    '/news/update/<%= news.slug %>',

                    {

                        method: 'PUT',

                        headers: {
                            'Content-Type':
                                'application/json'
                        },

                        body:
                            JSON.stringify(data)

                    }

                );

            const result =
                await response.text();

            alert(result);

            setTimeout(() => {

                window.location.href =
                    '/news';

            }, 1000);

        }
        catch(err){

            console.log(err);

            alert(
                'Update failed'
            );

        }

    });

});

</script>