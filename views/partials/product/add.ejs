
<div class="row clearfix">
    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
        <div class="card">

            <div class="header">
                <h2>➕ THÊM SẢN PHẨM</h2>
            </div>

            <div class="body">

                <!-- NAME -->
                <div class="form-group">
                    <label class="form-label">Tên sản phẩm</label>
                    <input type="text" class="form-input" id="productname">
                </div>

                <!-- CODE -->
                <div class="alert alert-info" style="margin-top:10px;">
                    <strong>Lưu ý:</strong>
                    Mã sản phẩm sẽ được tạo tự động theo danh mục.
                </div>

                <!-- PRICE -->
                <div class="form-group">
                    <label class="form-label">Giá</label>
                    <input type="number" class="form-input" id="price">
                </div>

                <!-- BRAND -->
                <div class="form-group">
                    <label class="form-label">Thương hiệu</label>
                    <select id="brand" class="form-control order-status-select">
                        <option>Adidas</option>
                        <option>Nike</option>
                        <option>Puma</option>
                        <option>Mizuno</option>
                    </select>
                </div>

                <!-- GROUP -->
                <div class="form-group">
                    <label>Danh mục</label>
                    <select id="group" 
                            class="form-control order-status-select">
                        <% categories.forEach(c => { %>
                            <option value="<%= c.group %>"><%= c.group %></option>
                        <% }) %>
                    </select>
                </div>

                <!-- VARIANTS -->
                <h4>📦 Biến thể sản phẩm</h4>

                <table class="table table-bordered" id="variantTable">
                    <thead>
                        <tr>
                            <th>Size</th>
                            <th>Màu</th>
                            <th>Stock</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td><input type="text" class="form-control size"></td>
                            <td><input type="text" class="form-control color"></td>
                            <td><input type="number" class="form-control stock" value="0"></td>
                            <td>
                                <button type="button" class="btn btn-danger btn-remove">X</button>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <button type="button" class="btn btn-primary" id="addVariant">
                    + Thêm biến thể
                </button>

                <hr>

                <!-- DESCRIPTION -->
                <div class="form-group">
                    <label>Mô tả</label>
                    <textarea id="description"></textarea>
                </div>

                <!-- IMAGE -->
                <div class="form-group">
                    <label>Ảnh</label>
                    <input type="file" id="file" multiple class="form-control" accept="image/*">                    
                    <button id="btnAddImage" class="btn btn-primary" style="margin-top:10px;">Upload ảnh</button>

                    <div id="list-product-image" style="margin-top:10px;"></div>
                </div>

                <button class="btn btn-success" id="addProduct">
                    Thêm sản phẩm
                </button>

            </div>
        </div>
    </div>
</div>

<script>

window.addEventListener('load', function(){

    // ================= SUMMERNOTE =================

    $('#description').summernote({

        height: 250,

        placeholder: 'Nhập mô tả sản phẩm...'

    });


    // ================= ADD VARIANT =================

    $('#addVariant').click(function () {

        $('#variantTable tbody').append(`

            <tr>

                <td>

                    <input
                        type="text"
                        class="form-control size">

                </td>

                <td>

                    <input
                        type="text"
                        class="form-control color">

                </td>

                <td>

                    <input
                        type="number"
                        class="form-control stock"
                        value="0">

                </td>

                <td>

                    <button
                        type="button"
                        class="btn btn-danger btn-remove">

                        X

                    </button>

                </td>

            </tr>

        `);

    });


    // ================= REMOVE VARIANT =================

    $(document).on(
        'click',
        '.btn-remove',
        function () {

            $(this)
                .closest('tr')
                .remove();

        }
    );


    // ================= IMAGE =================

    $('#btnAddImage').click(function (e) {

        e.preventDefault();

        const files =
            $('#file')[0].files;

        for (let i = 0; i < files.length; i++) {

            const file = files[i];

            if (!file.type.startsWith('image/')) {

                alert('Chỉ được upload ảnh!');

                continue;

            }

            const formData =
                new FormData();

            formData.append(
                'file',
                file
            );

            formData.append(
                'group',
                $('#group').val()
            );

            $.ajax({

                url: '/upload',

                type: 'POST',

                data: formData,

                contentType: false,

                processData: false,

                success: function (url) {

                    $('#list-product-image').append(`

                        <div>

                            <img
                                src="${url}"
                                width="120"
                                style="
                                    border-radius:8px;
                                    border:1px solid #ddd;
                                ">

                        </div>

                    `);

                },

                error: function () {

                    alert('Upload ảnh thất bại!');

                }

            });

        }

    });


    // ================= SUBMIT =================

    $('#addProduct').click(function () {

        const name =
            $('#productname').val();

        const price =
            $('#price').val();

        const brand =
            $('#brand').val();

        const group =
            $('#group').val();

        const description =
            $('#description')
                .summernote('code');

        let variants = [];

        $('#variantTable tbody tr').each(function () {

            let size =
                $(this).find('.size').val();

            let color =
                $(this).find('.color').val();

            let stock =
                $(this).find('.stock').val();

            if (size && color) {

                variants.push({

                    size,

                    color,

                    stock: parseInt(stock)

                });

            }

        });

        let images = [];

        $('#list-product-image img').each(function () {

            images.push(
                $(this).attr('src')
            );

        });

        const data = {

            name,

            price,

            brand,

            group,

            description,

            images,

            variants

        };

        $.ajax({

            url: '/product/add',

            method: 'POST',

            contentType: 'application/json',

            data: JSON.stringify(data),

            success: function () {

                alert('Thêm sản phẩm thành công!');

                window.location.href =
                    '/product';

            },

            error: function () {

                alert('Thêm sản phẩm thất bại!');

            }

        });

    });

});

</script>