<div class="card">

    <div class="header">
        <h2>✏️ CHỈNH SỬA SẢN PHẨM</h2>
    </div>

    <div class="body">

        <!-- NAME -->
        <div class="form-group">
            <label>Tên sản phẩm</label>

            <input
                type="text"
                id="name"
                class="form-control"
                value="<%= product.name %>"
            >
        </div>

        <!-- PRICE -->
        <div class="form-group">
            <label>Giá sản phẩm</label>

            <input
                type="number"
                id="price"
                class="form-control"
                value="<%= product.price %>"
            >
        </div>

        <!-- BRAND -->
        <div class="form-group">
            <label>Thương hiệu</label>

            <select id="brand" class="form-control order-status-select">
                        <option>Adidas</option>
                        <option>Nike</option>
                        <option>Puma</option>
                        <option>Mizuno</option>
                    </select>
        </div>

        <!-- GROUP -->
        <div class="form-group">
            <label>Danh mục</label>
            <select id="group" class="form-control order-status-select">
                <% categories.forEach(c => { %>
                    <option value="<%= c.group %>" <%= product.group === c.group ? 'selected' : '' %>>
                        <%= c.name || c.group %>
                    </option>
                <% }) %>
            </select>

            <!-- <select id="group" class="form-control order-status-select">

                <option
                    value="GIAY"
                    <%= product.group === 'GIAY' ? 'selected' : '' %>
                >
                    Giày
                </option>

                <option
                    value="AOCLB"
                    <%= product.group === 'AOCLB' ? 'selected' : '' %>
                >
                    Áo CLB
                </option>
                <option
                    value="AOQG"
                    <%= product.group === 'AOQG' ? 'selected' : '' %>
                >
                    Áo QG
                </option>
                <option
                    value="AOTRAINING"
                    <%= product.group === 'AOTRAINING' ? 'selected' : '' %>
                >
                    Áo Training
                </option>
                <option
                    value="PHUKIEN"
                    <%= product.group === 'PHUKIEN' ? 'selected' : '' %>
                >
                    Phụ kiện
                </option>
            </select> -->
        </div>

        <!-- DESCRIPTION -->
        <div class="form-group">
            <label>Mô tả sản phẩm</label>

            <textarea
                id="description"
                class="form-control summernote"
            ><%- product.description %></textarea>
        </div>

        <hr>

        <!-- IMAGES -->
        <h4>🖼 Ảnh sản phẩm</h4>

        <input
            type="file"
            id="files"
            multiple
            class="form-control"
        >

        <br>

        <!-- PREVIEW -->
        <div
            id="preview-images"
            style="
                display:flex;
                gap:10px;
                flex-wrap:wrap;
            "
        >

            <% product.images.forEach((img,index)=>{ %>

                <div
                    class="image-item"
                    data-url="<%= img %>"
                    style="position:relative;"
                >

                    <img
                        src="<%= img %>"
                        width="120"
                        style="
                            border-radius:8px;
                            border:1px solid #ddd;
                        "
                    >

                    <button
                        type="button"
                        class="btn btn-danger btn-sm remove-image"
                        style="
                            position:absolute;
                            top:0;
                            right:0;
                        "
                    >
                        ×
                    </button>

                </div>

            <% }) %>

        </div>

        <hr>

        <!-- VARIANTS -->
        <h4>📦 Biến thể sản phẩm</h4>

        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Size</th>
                    <th>Màu</th>
                    <th>Tồn kho</th>
                    <th></th>
                </tr>
            </thead>

            <tbody id="variant-body">

                <% product.variants.forEach(v=>{ %>

                    <tr>

                        <td>
                            <select class="form-control size" data-selected="<%= v.size %>">
                            </select>
                        </td>

                        <td>
                            <select class="form-control color">
                                <% ['Đỏ', 'Xanh dương', 'Xanh lá', 'Vàng', 'Cam', 'Tím', 'Đen', 'Trắng', 'Xám', 'Hồng', 'Nâu'].forEach(function(c) { %>
                                    <option value="<%= c %>" <%= v.color == c ? 'selected' : '' %>><%= c %></option>
                                <% }); %>
                                
                                <!-- Giữ lại giá trị cũ nếu nó không nằm trong danh sách chuẩn -->
                                <% if (!['Đỏ', 'Xanh dương', 'Xanh lá', 'Vàng', 'Cam', 'Tím', 'Đen', 'Trắng', 'Xám', 'Hồng', 'Nâu'].includes(v.color.toString())) { %>
                                    <option value="<%= v.color %>" selected><%= v.color %></option>
                                <% } %>
                            </select>
                        </td>

                        <td>
                            <input
                                type="number"
                                class="form-control stock"
                                value="<%= v.stock %>"
                            >
                        </td>

                        <td>
                            <button
                                class="btn btn-danger btn-remove-variant"
                            >
                                Xóa
                            </button>
                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

        <button
            type="button"
            class="btn btn-success"
            id="btn-add-variant"
        >
            + Thêm biến thể
        </button>

        <hr>

        <!-- STATUS -->
        <div class="form-group">

            <label>Trạng thái</label>

            <select id="isActive" class="form-control">

                <option
                    value="true"
                    <%= product.isActive ? 'selected' : '' %>
                >
                    Đang bán
                </option>

                <option
                    value="false"
                    <%= !product.isActive ? 'selected' : '' %>
                >
                    Ngừng bán
                </option>

            </select>

        </div>

        <br>

        <button
            class="btn btn-primary"
            id="btn-update"
        >
            💾 Cập nhật sản phẩm
        </button>

        <a href="/product" class="btn btn-default">
            ← Quay lại
        </a>

    </div>
</div>

<script>

window.addEventListener('load', function(){

    $('.summernote').summernote({
        height: 250
    });

    let uploadedImages = <%- JSON.stringify(product.images) %>;

    // ================= DYNAMIC SIZE BY CATEGORY =================
    function getSizeOptions(groupName, selectedSize = '') {
        const group = (groupName || '').toUpperCase();
        let html = '';
        
        if (group.includes('GIAY') || group.includes('GIÀY')) {
            const sizes = ['38', '39', '40', '41', '42', '43', '44'];
            sizes.forEach(s => {
                html += `<option value="${s}" ${selectedSize == s ? 'selected' : ''}>${s}</option>`;
            });
            if (selectedSize && !sizes.includes(selectedSize.toString())) {
                 html += `<option value="${selectedSize}" selected>${selectedSize}</option>`;
            }
        } else if (group.includes('PHUKIEN') || group.includes('PHỤ KIỆN')) {
            const sizes = ['Free Size', '8', '9', '10', 'Khác'];
            const labels = {'Free Size': 'Free Size', '8': '8 (Găng tay)', '9': '9 (Găng tay)', '10': '10 (Găng tay)', 'Khác': 'Khác'};
            sizes.forEach(s => {
                html += `<option value="${s}" ${selectedSize == s ? 'selected' : ''}>${labels[s]}</option>`;
            });
            if (selectedSize && !sizes.includes(selectedSize.toString())) {
                 html += `<option value="${selectedSize}" selected>${selectedSize}</option>`;
            }
        } else {
            // Mặc định cho Áo (AOCLB, AOQG, AOTRAINING...)
            const sizes = ['S', 'M', 'L', 'XL', 'XXL'];
            sizes.forEach(s => {
                html += `<option value="${s}" ${selectedSize == s ? 'selected' : ''}>${s}</option>`;
            });
            if (selectedSize && !sizes.includes(selectedSize.toString())) {
                 html += `<option value="${selectedSize}" selected>${selectedSize}</option>`;
            }
        }
        return html;
    }

    function renderSizes() {
        const currentGroup = $('#group').val();
        $('.size').each(function() {
            const selected = $(this).attr('data-selected') || $(this).val();
            const optionsHtml = getSizeOptions(currentGroup, selected);
            $(this).html(optionsHtml);
            $(this).removeAttr('data-selected'); 
        });
    }

    $('#group').change(function() {
        renderSizes();
    });

    // Kích hoạt lần đầu để render size cho các biến thể có sẵn
    renderSizes();

    // ================= REMOVE IMAGE =================

    $(document).on('click','.remove-image',function(){

        $(this).parent().remove();

    });

    // ================= ADD VARIANT =================

    $('#btn-add-variant').click(function(){

        const currentGroup = $('#group').val();
        const sizeOptionsHtml = getSizeOptions(currentGroup);

        $('#variant-body').append(`

            <tr>

                <td>
                    <select class="form-control size">
                        ${sizeOptionsHtml}
                    </select>
                </td>

                <td>
                    <select class="form-control color">
                        <option value="Đỏ">Đỏ</option>
                        <option value="Xanh dương">Xanh dương</option>
                        <option value="Xanh lá">Xanh lá</option>
                        <option value="Vàng">Vàng</option>
                        <option value="Cam">Cam</option>
                        <option value="Tím">Tím</option>
                        <option value="Đen">Đen</option>
                        <option value="Trắng">Trắng</option>
                        <option value="Xám">Xám</option>
                        <option value="Hồng">Hồng</option>
                        <option value="Nâu">Nâu</option>
                    </select>
                </td>

                <td>
                    <input
                        type="number"
                        class="form-control stock"
                        value="0"
                    >
                </td>

                <td>

                    <button
                        class="btn btn-danger btn-remove-variant">

                        Xóa

                    </button>

                </td>

            </tr>

        `);

    });

    // ================= REMOVE VARIANT =================

    $(document).on('click','.btn-remove-variant',function(){

        $(this).closest('tr').remove();

    });

    // ================= UPLOAD IMAGE =================

    $('#files').change(async function(){

        const files = this.files;

        for(let file of files){

            let formData = new FormData();

            formData.append('file',file);

            formData.append(
                'folder',
                $('#group').val()
            );

            const res = await fetch('/upload',{

                method:'POST',

                body:formData

            });

            const response = await res.json();

            uploadedImages.push(response.url);

            $('#preview-images').append(`

                <div
                    class="image-item"
                    data-url="${response.url}"
                    style="position:relative;"
                >

                    <img
                        src="${response.url}"
                        width="120"
                        style="
                            border-radius:8px;
                            border:1px solid #ddd;
                        "
                    >

                    <button
                        type="button"
                        class="btn btn-danger btn-sm remove-image"
                        style="
                            position:absolute;
                            top:0;
                            right:0;
                        "
                    >

                        ×

                    </button>

                </div>

            `);

        }

    });

    // ================= UPDATE PRODUCT =================

    $('#btn-update').click(async function(){

        const variants = [];

        $('#variant-body tr').each(function(){

            variants.push({

                size: $(this).find('.size').val(),

                color: $(this).find('.color').val(),

                stock: Number(
                    $(this).find('.stock').val()
                )

            });

        });

        const images = [];

        $('.image-item').each(function(){

            images.push($(this).data('url'));

        });

        const body = {

            name: $('#name').val(),

            price: Number($('#price').val()),

            brand: $('#brand').val(),

            group: $('#group').val(),

            description:
                $('#description')
                    .summernote('code'),

            images,

            variants,

            isActive:
                $('#isActive').val() === 'true'

        };

        const res = await fetch(

            '/product/update/<%= product.productCode %>',

            {

                method:'PUT',

                headers:{
                    'Content-Type':'application/json'
                },

                body:JSON.stringify(body)

            }

        );

        const text = await res.text();

        alert(text);

        // location.reload();
        window.location.href = '/product';
    });

});

</script>