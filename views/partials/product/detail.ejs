<div class="row clearfix">
    <div class="col-lg-12">
        <div class="card">

            <div class="header">
                <h2>📦 CHI TIẾT SẢN PHẨM - <%= product.productCode %></h2>
            </div>

            <div class="body">

                <!-- NAME -->
                <div class="form-group">
                    <label>Tên sản phẩm</label>
                    <input type="text" class="form-control" value="<%= product.name %>" disabled>
                </div>

                <!-- PRICE -->
                <div class="form-group">
                    <label>Giá</label>
                    <input type="text" class="form-control" value="<%= product.price.toLocaleString() %> ₫" disabled>
                </div>

                <!-- BRAND -->
                <div class="form-group">
                    <label>Thương hiệu</label>
                    <input type="text" class="form-control" value="<%= product.brand %>" disabled>
                </div>

                <!-- GROUP -->
                <div class="form-group">
                    <label>Danh mục</label>
                    <input type="text" class="form-control" value="<%= product.group %>" disabled>
                </div>

                <hr>

                <!-- VARIANTS -->
                <h4>📦 Biến thể sản phẩm</h4>

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Size</th>
                            <th>Màu</th>
                            <th>Stock</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% product.variants.forEach(v => { %>
                            <tr>
                                <td><%= v.size %></td>
                                <td><%= v.color %></td>
                                <td><%= v.stock %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>

                <hr>

                <!-- DESCRIPTION -->
                <h4>Mô tả</h4>
                <div style="border:1px solid #ddd; padding:10px;">
                    <%- product.description %>
                </div>

                <hr>

                <!-- IMAGES -->
                <h4>Ảnh sản phẩm</h4>

                <div style="display:flex; gap:10px; flex-wrap:wrap;">

                    <% if(product.images && product.images.length > 0){ %>

                        <% product.images.forEach(img => { %>

                            <img
                                src="<%= img %>"
                                width="120"
                                style="border-radius:6px;"
                            >

                        <% }) %>

                    <% } else { %>

                        <img
                            src="/images/no-image.jpg"
                            width="120"
                            style="border-radius:6px;"
                        >

                    <% } %>

                </div>

                <hr>

                <!-- TOTAL STOCK -->
                <%
                    let totalStock = 0;
                    product.variants.forEach(v => totalStock += v.stock);
                %>

                <h4>
                    📊 Tổng tồn kho: <%= totalStock %>
                </h4>

                <br>

                <a href="/product/edit/<%= product.productCode %>" class="btn btn-primary">
                    ✏️ Chỉnh sửa
                </a>

                <a href="/product" class="btn btn-default">
                    ← Quay lại
                </a>

            </div>
        </div>
    </div>
</div>