
<div class="row clearfix">

    <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

        <div class="card">

            <!-- ================= HEADER ================= -->

            <div class="header">

                <h2>
                    📦 DANH SÁCH SẢN PHẨM
                </h2>

            </div>

            <!-- ================= FILTER ================= -->

            <div class="admin-filter-bar">

                <!-- KEYWORD -->

                <input

                    type="text"

                    placeholder="🔍 Tên hoặc mã..."

                    id="keyword"

                    value="<%= keyword || '' %>"

                    class="form-control admin-filter-field admin-filter-field--keyword"
                >

                <!-- GROUP -->

                <select
                    id="group"
                    class="form-control admin-filter-field admin-filter-field--category">

                    <option value="">
                        Danh mục
                    </option>

                    <option
                        value="GIAY"
                        <%= group=='GIAY'
                            ? 'selected'
                            : ''
                        %>>

                        Giày

                    </option>

                    <option
                        value="AOCLB"
                        <%= group=='AOCLB'
                            ? 'selected'
                            : ''
                        %>>

                        Áo CLB

                    </option>

                </select>

                <!-- MIN PRICE -->

                <input

                    type="number"

                    placeholder="Giá từ"

                    id="minPrice"

                    value="<%= minPrice || '' %>"

                    class="form-control admin-filter-field admin-filter-field--price"
                >

                <!-- MAX PRICE -->

                <input

                    type="number"

                    placeholder="Đến"

                    id="maxPrice"

                    value="<%= maxPrice || '' %>"

                    class="form-control admin-filter-field admin-filter-field--price"
                >

                <%- include('../shared/date-filter', { fromDate, toDate }) %>

                <div class="admin-filter-actions">

                    <!-- SEARCH -->

                    <button
                        class="btn btn-primary"
                        onclick="searchProduct()">

                        Tìm

                    </button>

                    <!-- ADD PRODUCT -->

                    <a
                        href="/product/add"
                        class="btn btn-success">

                        <i class="material-icons">
                            add
                        </i>

                        Thêm sản phẩm

                    </a>

                </div>

            </div>

            <!-- ================= TABLE ================= -->

            <div class="body">

                <div class="table-responsive">

                    <table
                        class="table table-bordered table-hover dataTable">

                        <thead
                            style="text-align:center;">

                            <tr>

                                <th>Ảnh</th>

                                <th>Mã SP</th>

                                <th>Tên</th>

                                <th>Giá</th>

                                <th>Tồn kho</th>

                                <th>Trạng thái</th>

                                <th class="col-sm-3">
                                    Hành động
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <% products.forEach(function(p){ %>

                                <tr>

                                    <!-- IMAGE -->

                                    <td
                                        style="
                                            text-align:center;
                                            vertical-align:middle;
                                        ">

                                        <img

                                            src="<%= p.images
                                                &&
                                                p.images.length
                                                    ? p.images[0]
                                                    : '/images/no-image.jpg'
                                            %>"

                                            width="70"

                                            height="70"

                                            style="
                                                object-fit:cover;
                                                border-radius:8px;
                                                border:1px solid #ddd;
                                            "
                                        >

                                    </td>

                                    <!-- PRODUCT CODE -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                            font-weight:bold;
                                        ">

                                        <%= p.productCode %>

                                    </td>

                                    <!-- NAME -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                        ">

                                        <%= p.name %>

                                    </td>

                                    <!-- PRICE -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                            color:red;
                                            font-weight:bold;
                                        ">

                                        <%= formatCurrency(
                                            p.price
                                        ) %>

                                    </td>

                                    <!-- STOCK -->

                                    <td
                                        style="
                                            text-align:center;
                                            vertical-align:middle;
                                        ">

                                        <span
                                            class="badge bg-blue">

                                            <%= calculateStock(
                                                p.variants
                                            ) %>

                                        </span>

                                    </td>

                                    <!-- STATUS -->

                                    <td
                                        style="
                                            text-align:center;
                                            vertical-align:middle;
                                        ">

                                        <% if(p.isActive){ %>

                                            <span
                                                class="badge bg-green">

                                                Đang bán

                                            </span>

                                        <% } else { %>

                                            <span
                                                class="badge bg-grey">

                                                Ngừng bán

                                            </span>

                                        <% } %>

                                    </td>

                                    <!-- ACTION -->

                                    <td
                                        style="
                                            vertical-align:middle;
                                        ">

                                        <div
                                            style="
                                                display:flex;
                                                gap:5px;
                                                flex-wrap:wrap;
                                            ">

                                            <!-- DETAIL -->

                                            <a

                                                class="btn btn-info btn-sm"

                                                href="/product/detail/<%= p.productCode %>">

                                                Chi tiết

                                            </a>

                                            <!-- EDIT -->

                                            <a

                                                class="btn btn-primary btn-sm"

                                                href="/product/edit/<%= p.productCode %>">

                                                Sửa

                                            </a>

                                            <!-- ACTIVE / INACTIVE -->

                                            <% if(p.isActive){ %>

                                                <a

                                                    class="btn btn-danger btn-sm"

                                                    href="/product/delete/<%= p.productCode %>"

                                                    onclick="return confirm('Xác nhận ngừng bán?')">

                                                    Ngừng bán

                                                </a>

                                            <% } else { %>

                                                <a

                                                    class="btn btn-success btn-sm"

                                                    href="/product/active/<%= p.productCode %>">

                                                    Bật lại

                                                </a>

                                            <% } %>

                                        </div>

                                    </td>

                                </tr>

                            <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- ================= PAGINATION ================= -->

<div class="row clearfix">

    <% if(pages > 0) { %>

        <ul class="pagination mx-auto">

            <!-- FIRST -->

            <li
                class="page-item <%= current == 1 ? 'disabled' : '' %>">

                <a

                    class="page-link"

                    href="/product?page=1<%= queryString ? '&' + queryString : '' %>">

                    First

                </a>

            </li>

            <!-- PAGE NUMBER -->

            <% for(let i = 1; i <= pages; i++){ %>

                <li
                    class="page-item <%= current == i ? 'active' : '' %>">

                    <a

                        class="page-link"

                        href="/product?page=<%= i %><%= queryString ? '&' + queryString : '' %>">

                        <%= i %>

                    </a>

                </li>

            <% } %>

            <!-- LAST -->

            <li
                class="page-item <%= current == pages ? 'disabled' : '' %>">

                <a

                    class="page-link"

                    href="/product?page=<%= pages %><%= queryString ? '&' + queryString : '' %>">

                    Last

                </a>

            </li>

        </ul>

    <% } %>

</div>

<!-- ================= SCRIPT ================= -->

<script>

function searchProduct(){

    const keyword =
        document.getElementById(
            'keyword'
        ).value;

    const group =
        document.getElementById(
            'group'
        ).value;

    const minPrice =
        document.getElementById(
            'minPrice'
        ).value;

    const maxPrice =
        document.getElementById(
            'maxPrice'
        ).value;

    const params =
        appendAdminDateParams(
            new URLSearchParams()
        );

    if(!params){
        return;
    }

    // ================= KEYWORD =================

    if(keyword){

        params.set('keyword', keyword);

    }

    // ================= GROUP =================

    if(group){

        params.set('group', group);

    }

    // ================= MIN PRICE =================

    if(minPrice){

        params.set('minPrice', minPrice);

    }

    // ================= MAX PRICE =================

    if(maxPrice){

        params.set('maxPrice', maxPrice);

    }

    window.location.href =
        `/product?${params.toString()}`;

}

</script>
